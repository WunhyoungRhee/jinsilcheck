# Azure Cosmos DB
COSMOS_DB_ENDPOINT=https://your-cosmosdb.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-key
COSMOS_DB_DATABASE=jinsilcheck
COSMOS_DB_CONTAINER=analysis-cache

# SightEngine API (https://sightengine.com)
SIGHTENGINE_API_USER=your-api-user
SIGHTENGINE_API_SECRET=your-api-secret

# Hive AI API (https://thehive.ai)
HIVE_API_KEY=your-hive-api-key
